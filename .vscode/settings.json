{
    "files.watcherExclude": {
        "**/.build/**": true,
        "**/target/**": true
    },
    "yaml.schemas": {
        "https://json-schema.org/draft/2019-09/schema": [
            "schema.yaml",
            "*.schema.yaml"
        ]
    },
    "sqltools.format": {
        "linesBetweenQueries": 2,
        "reservedWordCase": "upper",
        "language": "sql"
    },
    "files.trimTrailingWhitespace": true,
    "editor.formatOnSave": true,
    "cSpell.words": [
        "airbyte",
        "Firebolt",
        "schemalate"
    ],
    "[sql]": {
        // Disable SQL formatting because it's - frankly - terrible.
        "editor.formatOnSave": false
    },
    "[typescript]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "denoland.vscode-deno"
    },
    "deno.enablePaths": [
        "./supabase/functions"
    ],
    "deno.config": "./deno.jsonc",
    "deno.lint": true,
    "deno.path": ".build/package/bin/deno",
    "rust-analyzer.imports.group.enable": false,
    "go.goroot": "~/.local/share/mise/installs/go/1.25.3/",
    "go.buildTags": "libsqlite3",
    "go.toolsEnvVars": {
        "CGO_LDFLAGS": "-fuse-ld=mold -L /dev-one/cargo-target/debug -L /Users/johnny/Work/estuary/flow-devex-spike/.build/rocksdb/lib -lbindings -lrocksdb -lsnappy -lstdc++ -lssl -lcrypto -ldl -lm",
        "CGO_CFLAGS": "-I /Users/johnny/Work/estuary/flow-devex-spike/.build/rocksdb/include",
        "CGO_CPPFLAGS": "-I /Users/johnny/Work/estuary/flow-devex-spike/.build/rocksdb/include",
    },
    "rust-analyzer.cargo.extraEnv": {
        "ROCKSDB_VERSION": "9.10.0",
        "ROCKSDB_INCLUDE_DIR": "/Users/johnny/Work/estuary/flow-devex-spike/.build/rocksdb/include",
        "ROCKSDB_LIB_DIR": "/Users/johnny/Work/estuary/flow-devex-spike/.build/rocksdb/lib",
        "RUSTFLAGS": "-D warnings -C link-arg=-fuse-ld=mold",
        "SNAPPY_STATIC": "1",
        "SNAPPY_LIB_DIR": "/usr/lib/aarch64-linux-gnu",
        "JEMALLOC_OVERRIDE": "/usr/lib/aarch64-linux-gnu/libjemalloc.a"
    },
    "rust-analyzer.cachePriming.enable": false
}