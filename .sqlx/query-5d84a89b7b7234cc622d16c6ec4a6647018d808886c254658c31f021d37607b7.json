  "query": "\n        SELECT\n            ug.user_id AS \"user_id!: uuid::Uuid\",\n            u.email AS \"email: String\"\n        FROM user_grants ug\n        LEFT JOIN auth.users u ON u.id = ug.user_id\n        WHERE ug.object_role = $1\n            AND ug.capability = $2\n        ",
