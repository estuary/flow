#!/usr/bin/env bash
set -euo pipefail

# Run the example catalog's tests on the Rust-only runtime-next harness
# (`flowctl test`): no Gazette broker, etcd, Go consumer, or flowctl-go binary.
# Derivations run as resident runtime-next sessions (derive-sqlite in-process,
# TypeScript derivations as image containers on the default Docker network).
cargo run -p flowctl -- test --source examples/flow.yaml
