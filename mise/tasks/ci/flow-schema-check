#!/usr/bin/env bash
#MISE description="Verify the committed flow.schema.json is up-to-date"

set -euo pipefail

# Regenerate the schema from crates/models via flowctl; see `build:flow-schema`.
mise run build:flow-schema

# Fail if the committed copy drifted from what the models now produce.
if ! git diff --exit-code -- flow.schema.json; then
  echo >&2 "error: committed flow.schema.json is out of date."
  echo >&2 "run 'mise run build:flow-schema' and commit flow.schema.json"
  exit 1
fi
