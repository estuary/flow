#!/usr/bin/env bash
set -euo pipefail

# CARGO_TARGET_DIR is per-checkout (see mise/tasks/local/stack-env); go tests
# locate flow-connector-init (musl) and other Rust binaries on PATH. mise's
# _.path already covers ${CARGO_TARGET_DIR}/debug, but not the musl target dir.
GORACE="halt_on_error=1" \
PATH=${PATH}:${CARGO_TARGET_DIR}/debug:${CARGO_TARGET_DIR}/$(uname -m)-unknown-linux-musl/debug \
go test -tags libsqlite3 --race --count=5 --failfast ./go/...