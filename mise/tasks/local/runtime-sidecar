#!/usr/bin/env bash
set -euo pipefail

#MISE description="Start runtime-v2 sidecar for a local data plane via systemd (for this stack)"
#MISE depends=["local:tls-cert"]
#USAGE arg "<data_plane>" help="Name of the data plane"
#USAGE arg "<base_port>" help="Base port block for the data plane"

source "$(dirname "$0")/lib.sh"
ensure_stack_env
prepare_dirs

DATA_PLANE="${usage_data_plane}"
BASE_PORT="${usage_base_port}"

HMAC_KEY=$(echo -n "key-${DATA_PLANE}" | base64 | tr -d '\n')
SIDECAR_PORT=$((BASE_PORT + 60))
ADMIN_PORT=$((BASE_PORT + 61))

if [ $((BASE_PORT % 100)) -ne 0 ]; then
    echo "Error: Port block ${BASE_PORT} must be divisible by 100 (e.g., ${FLOW_PLANE_BASE})" >&2
    exit 1
fi

{
    emit_common_vars
    cat <<EOF

# Runtime sidecar environment for ${DATA_PLANE}
ADMIN_PORT=${ADMIN_PORT}
AGENT_ENDPOINT=http://agent.flow.localhost:${FLOW_PORT_AGENT}
CERTIFICATE_FILE=${FLOW_LOCAL}/server.crt
CERTIFICATE_KEY_FILE=${FLOW_LOCAL}/server.key
DATA_PLANE_AUTH_KEYS=${HMAC_KEY}
DATA_PLANE_FQDN=${DATA_PLANE}.dp.estuary-data.com
GAZETTE_ZONE=local
LISTEN_PORT=${SIDECAR_PORT}
NO_COLOR=1
PEER_ENDPOINT=https://reactor-${DATA_PLANE}.flow.localhost:${SIDECAR_PORT}
RUST_LOG=info
SSL_CERT_FILE=${FLOW_LOCAL}/ca.crt
EOF
} > "${FLOW_ENV_DIR}/runtime-sidecar-${DATA_PLANE}.env"

# Bind this sidecar to the data-plane target.
DROPIN_DIR="${HOME}/.config/systemd/user/flow-runtime-sidecar@${DATA_PLANE}.service.d"
mkdir -p "$DROPIN_DIR"
cat > "${DROPIN_DIR}/plane.conf" <<EOF
[Unit]
PartOf=flow-plane@${DATA_PLANE}.target
After=flow-plane@${DATA_PLANE}.target
EOF

DROPIN_DIR="${HOME}/.config/systemd/user/flow-plane@${DATA_PLANE}.target.d"
mkdir -p "$DROPIN_DIR"
cat > "${DROPIN_DIR}/wants-runtime-sidecar.conf" <<EOF
[Unit]
Wants=flow-runtime-sidecar@${DATA_PLANE}.service
EOF

link_unit flow-plane@.target
link_unit flow-runtime-sidecar@.service

systemctl --user daemon-reload
systemctl --user restart "flow-runtime-sidecar@${DATA_PLANE}.service"

echo "Created flow-runtime-sidecar@${DATA_PLANE} on port ${SIDECAR_PORT} (admin: http://127.0.0.1:${ADMIN_PORT}/)"
