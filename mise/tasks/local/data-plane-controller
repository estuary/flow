#!/usr/bin/env bash
set -euo pipefail

#MISE description="Start data-plane-controller (service + job) in dry-run mode via systemd (for this stack)"
#MISE depends=["local:supabase"]

source "$(dirname "$0")/lib.sh"
ensure_stack_env
prepare_dirs

NAME="${FLOW_STACK_NAME}"
DBURL="postgresql://postgres:postgres@db.flow.localhost:${FLOW_PORT_SUPABASE_DB}/postgres"
# The controller's HTTP port lives in this stack's block (offset +40, reserved
# for the dev-facing data-plane-controller) so multiple stacks run concurrently.
DPC_PORT=$((FLOW_STACK_BASE + 40))

# Create environment file for the Service (Worker)
{
    emit_common_vars
    cat <<EOF

# Data Plane Controller Service environment for stack ${NAME}.
DPC_DATABASE_URL=${DBURL}
DPC_PORT=${DPC_PORT}
RUST_LOG=info,data_plane_controller=debug
NO_COLOR=1
EOF
} > "${FLOW_ENV_DIR}/data-plane-controller-service-${NAME}.env"

# Create environment file for the Job (Dispatcher)
{
    emit_common_vars
    cat <<EOF

# Data Plane Controller Job environment (dry-run mode) for stack ${NAME}.
DPC_DATABASE_URL=${DBURL}
DPC_CONCURRENCY=2
DPC_DEQUEUE_INTERVAL=5s
DPC_HEARTBEAT_TIMEOUT=30s
DPC_GIT_REPO=git@github.com:estuary/est-dry-dock.git
DPC_OPS_GIT_REPO=git@github.com:estuary/ops.git
DPC_SERVICE_URL=http://localhost:${DPC_PORT}
RUST_LOG=info,data_plane_controller=debug
NO_COLOR=1
EOF
} > "${FLOW_ENV_DIR}/data-plane-controller-job-${NAME}.env"

link_unit flow-data-plane-controller-service@.service
link_unit flow-data-plane-controller-job@.service
systemctl --user daemon-reload

# Start service first, then job (job depends on service)
systemctl --user start "flow-data-plane-controller-service@${NAME}.service"
echo "✓ Service started"

# Give service a moment to start
sleep 2

systemctl --user start "flow-data-plane-controller-job@${NAME}.service"
echo "✓ Job started"

echo ""
echo "Data-plane-controller started in dry-run mode (Job + Service architecture)."
echo ""
echo "  Service Status: systemctl --user status flow-data-plane-controller-service@${NAME}"
echo "  Service Logs:   journalctl --user -u flow-data-plane-controller-service@${NAME} -f"
echo ""
echo "  Job Status:     systemctl --user status flow-data-plane-controller-job@${NAME}"
echo "  Job Logs:       journalctl --user -u flow-data-plane-controller-job@${NAME} -f"
echo ""
echo "  Stop Both:      systemctl --user stop flow-data-plane-controller-job@${NAME} flow-data-plane-controller-service@${NAME}"
echo ""
echo "NOTE: Dry-run mode simulates Pulumi/Ansible commands without executing them."
echo "      No cloud infrastructure changes will be made."
