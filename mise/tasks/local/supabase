#!/usr/bin/env bash
set -euo pipefail

#MISE description="Start Supabase via systemd (for this stack)"
#USAGE flag "--no-block" help="Do not wait for service to start"

source "$(dirname "$0")/lib.sh"
ensure_stack_env
prepare_dirs

NO_BLOCK="${usage_no_block:-false}"
NAME="${FLOW_STACK_NAME}"

# Consolidated supabase env file. Beyond the common build/runtime vars, it
# carries the FLOW_* values that config.toml's env() references resolve against
# (project id, ports, site url) and FLOW_STACK_DIR (sentinel location).
ENV_FILE="${FLOW_ENV_DIR}/supabase-${NAME}.env"
{
    emit_common_vars
    cat <<EOF

# Stack identity and ports (consumed by supabase/config.toml env() refs).
FLOW_STACK_DIR="${FLOW_STACK_DIR}"
FLOW_SUPABASE_PROJECT_ID="${FLOW_SUPABASE_PROJECT_ID}"
FLOW_PORT_SUPABASE_API="${FLOW_PORT_SUPABASE_API}"
FLOW_PORT_SUPABASE_DB="${FLOW_PORT_SUPABASE_DB}"
FLOW_PORT_SUPABASE_STUDIO="${FLOW_PORT_SUPABASE_STUDIO}"
FLOW_PORT_SUPABASE_MAILPIT="${FLOW_PORT_SUPABASE_MAILPIT}"
FLOW_SITE_URL="${FLOW_SITE_URL}"
EOF
} > "${ENV_FILE}"

cat > "${FLOW_ENV_DIR}/supabase-functions-${NAME}.env" <<EOF
# Environment for Supabase edge functions
# Generated by mise ($(date))

# Use this stack's config encryption service.
CONFIG_ENCRYPTION_URL=http://host.docker.internal:${FLOW_PORT_CONFIG_ENC}/v1/encrypt-config
EOF

link_unit flow-supabase@.service
systemctl --user daemon-reload

if [ "${NO_BLOCK}" = "true" ]; then
    systemctl --user start --no-block "flow-supabase@${NAME}"
    echo "Supabase starting (non-blocking). Wait for completion with: systemctl --user start flow-supabase@${NAME}"
else
    systemctl --user start "flow-supabase@${NAME}"
    echo "Supabase started."
fi

echo "Check status with: systemctl --user status flow-supabase@${NAME}"
echo "View logs with: journalctl --user -u flow-supabase@${NAME} -f"
echo "Database accessible at: postgresql://postgres:postgres@localhost:${FLOW_PORT_SUPABASE_DB}/postgres"
