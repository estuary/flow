#!/usr/bin/env bash
set -euo pipefail

#MISE description="Start control plane agent via systemd (for this stack)"
#MISE depends=["local:tls-cert", "local:supabase", "local:bigtable"]

source "$(dirname "$0")/lib.sh"
ensure_stack_env
prepare_dirs

NAME="${FLOW_STACK_NAME}"

# Agent env: this stack's API port, per-stack builds root and DB/bigtable ports,
# plus the common build/runtime vars (CARGO_TARGET_DIR for the binary path,
# FLOW_ROOT for the build step) and FLOW_PORT_DASHBOARD for --allow-origin.
{
    emit_common_vars
    cat <<EOF

# Agent environment for stack ${NAME}.
# SSL_CERT_FILE is required for calls made to brokers and reactors.

API_PORT=${FLOW_PORT_AGENT}
FLOW_PORT_DASHBOARD=${FLOW_PORT_DASHBOARD}
BUILDS_ROOT=file://${FLOW_STACK_DIR}/builds/
CONTROL_PLANE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
DATABASE_URL=postgresql://postgres:postgres@db.flow.localhost:${FLOW_PORT_SUPABASE_DB}/postgres
LOG_FORMAT=text
CONTROLLER_MAX_JOBS=10
SERVE_ALERT_NOTIFICATIONS=true
NO_COLOR=1
RUST_LOG=info
SERVE_HANDLERS=true
SKIP_CONNECTOR_TABLE_CHECK=true
SSL_CERT_FILE=${FLOW_LOCAL}/ca.crt

# Local stacks run the V2 task runtime for every newly-created task: the agent
# stamps enable-runtime-v2 onto new captures, derivations, and materializations
# at publication time. Existing tasks and explicit per-task flags are unaffected.
# See RuntimeV2Rollout in crates/control-plane-api.
RUNTIME_V2_NEW_CAPTURES=true
RUNTIME_V2_NEW_DERIVATIONS=true
RUNTIME_V2_NEW_MATERIALIZATIONS=true

BIGTABLE_PROJECT=estuary-local
BIGTABLE_INSTANCE=estuary-local
BIGTABLE_EMULATOR_HOST=localhost:${FLOW_PORT_BIGTABLE}
EOF
} > "${FLOW_ENV_DIR}/agent-${NAME}.env"

# Forward STRIPE_API_KEY from the invoking shell when set
# (e.g. a testmode key pasted before `mise run`). Without it, billing
# GraphQL operations return an error indicating billing is not configured.
if [ -n "${STRIPE_API_KEY:-}" ]; then
    echo "STRIPE_API_KEY=${STRIPE_API_KEY}" >> "${FLOW_ENV_DIR}/agent-${NAME}.env"
fi

{
    emit_common_vars
    cat <<EOF

# Config-encryption service environment for stack ${NAME}.
API_PORT=${FLOW_PORT_CONFIG_ENC}
RUST_LOG=info

# This matches SOPS_AGE_KEY in the reactor development task.
KMS_TYPE=age
KMS_KEY=age1z2qskpk8ww2rx5frxzykryufkfm9sj03v56m3qu54y0lgndytp3sdg24vs
EOF
} > "${FLOW_ENV_DIR}/config-encryption-${NAME}.env"

# Install the templated control-plane units (relink from this checkout).
link_unit flow-control-agent@.service
link_unit flow-config-encryption@.service
link_unit flow-control-plane@.target
systemctl --user daemon-reload
systemctl --user start "flow-control-plane@${NAME}.target"

# Generate this stack's flowctl profile. Every stack's profile needs explicit
# URLs: flowctl no longer compiles in any local defaults (ports are per-stack and
# dynamic). URLs are refreshed on every start because a checkout's index (and
# thus its ports) can change across re-allocations after a slot is reclaimed; a prior
# `flowctl --profile ${NAME} login` may have stored tokens we must preserve, so
# when a profile already exists we merge new URLs into it rather than overwrite.
PROFILE_DIR="${HOME}/.config/flowctl"
PROFILE_FILE="${PROFILE_DIR}/${NAME}.json"
PG_PUBLIC_TOKEN="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"
mkdir -p "${PROFILE_DIR}"
if [ -f "${PROFILE_FILE}" ]; then
    # Refresh URLs and the public token in place, preserving login tokens
    # (user_access_token / user_refresh_token) and any other fields.
    jq \
        --arg agent_url "http://localhost:${FLOW_PORT_AGENT}/" \
        --arg pg_url "http://localhost:${FLOW_PORT_SUPABASE_API}/rest/v1" \
        --arg dashboard_url "http://localhost:${FLOW_PORT_DASHBOARD}/" \
        --arg config_encryption_url "http://localhost:${FLOW_PORT_CONFIG_ENC}/" \
        --arg pg_public_token "${PG_PUBLIC_TOKEN}" \
        '.agent_url = $agent_url
            | .pg_url = $pg_url
            | .dashboard_url = $dashboard_url
            | .config_encryption_url = $config_encryption_url
            | .pg_public_token = $pg_public_token' \
        "${PROFILE_FILE}" > "${PROFILE_FILE}.tmp"
    mv "${PROFILE_FILE}.tmp" "${PROFILE_FILE}"
    echo "Refreshed flowctl profile ${PROFILE_FILE} (use: flowctl --profile ${NAME})"
else
    cat > "${PROFILE_FILE}" <<EOF
{
  "agent_url": "http://localhost:${FLOW_PORT_AGENT}/",
  "pg_url": "http://localhost:${FLOW_PORT_SUPABASE_API}/rest/v1",
  "dashboard_url": "http://localhost:${FLOW_PORT_DASHBOARD}/",
  "config_encryption_url": "http://localhost:${FLOW_PORT_CONFIG_ENC}/",
  "pg_public_token": "${PG_PUBLIC_TOKEN}"
}
EOF
    echo "Wrote flowctl profile ${PROFILE_FILE} (use: flowctl --profile ${NAME})"
fi

echo "Control-plane started. Check status with: systemctl --user status flow-control-plane@${NAME}.target"
echo "  Status: systemctl --user list-dependencies flow-control-plane@${NAME}.target"
