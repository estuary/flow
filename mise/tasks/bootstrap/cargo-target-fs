#!/usr/bin/env bash
set -euo pipefail

#MISE description="Mount a compressed, self-deduplicating btrfs filesystem at ~/cargo-target (dev VMs)"

# Per-checkout stacks give each checkout its own CARGO_TARGET_DIR under
# ~/cargo-target/<stack> (see mise/tasks/local/stack-env), and incremental
# builds are off (Cargo.toml sets incremental = false). Each such tree is
# 20-30G and the trees overlap heavily across checkouts. This task backs
# ~/cargo-target with a sparse loopback btrfs image that (a) transparently
# compresses artifacts (~3.2x measured, zstd:3) and (b) is dedupe-scanned +
# fstrimmed by a 10-minute systemd timer, so shared extents collapse and freed
# space is punched back into the sparse image. Net: many divergent checkouts
# fit in a fraction of the raw footprint.

IMAGE="${HOME}/cargo-target.img"
MOUNTPOINT="${HOME}/cargo-target"
HELPER="/usr/local/sbin/cargo-target-fs"
HASHFILE="${HOME}/.cache/cargo-target-dedupe.hash"

# mise tasks also run on macOS hosts; this filesystem trick is Linux-only.
if [[ "$(uname -s)" != "Linux" ]]; then
    echo "cargo-target-fs: not Linux; nothing to do."
    exit 0
fi

if mountpoint -q "${MOUNTPOINT}"; then
    echo "cargo-target-fs: ${MOUNTPOINT} is already a mountpoint; nothing to do."
    exit 0
fi

# A plain directory here is left untouched — no in-place migration. VMs are
# disposable, so the supported path to the compressed filesystem is a fresh VM.
if [[ -e "${MOUNTPOINT}" ]]; then
    echo "cargo-target-fs: ${MOUNTPOINT} exists as a plain path; leaving it alone."
    echo "cargo-target-fs: recreate the VM to adopt the compressed filesystem."
    exit 0
fi

sudo DEBIAN_FRONTEND=noninteractive apt-get install -y btrfs-progs duperemove

# Create the sparse backing image sized at 50% of the disk backing $HOME.
# btrfs stores compressed extents, so this caps *physical post-compression*
# bytes at 50% of the disk while holding ~2.4x the disk in logical artifacts at
# the measured 3.2x ratio — the virtual size is a logical-capacity ceiling, not
# a physical reservation (the file stays sparse; only real post-compression
# bytes occupy disk).
if [[ ! -e "${IMAGE}" ]]; then
    DISK_BYTES="$(df --block-size=1 --output=size "${HOME}" | tail -n1 | tr -d ' ')"
    IMAGE_BYTES=$(( DISK_BYTES * 50 / 100 ))
    truncate -s "${IMAGE_BYTES}" "${IMAGE}"
    echo "cargo-target-fs: created sparse ${IMAGE} of $(( IMAGE_BYTES / 1024 / 1024 / 1024 ))G virtual."
fi

# mkfs only if the image has no filesystem yet. The user owns the file, so
# mkfs.btrfs on it needs no root; blkid does (to read the raw device).
if ! sudo blkid "${IMAGE}" >/dev/null 2>&1; then
    mkfs.btrfs -q "${IMAGE}"
    echo "cargo-target-fs: formatted ${IMAGE} as btrfs."
fi

# Install the mount/umount helper with this user's HOME/USER baked in. It is
# driven by cargo-target-fs.service (mount/umount verbs) rather than an fstab
# `loop` entry specifically so we can enable direct-io on the loop device —
# fstab cannot express --direct-io=on, and DIO avoids double page-caching the
# image (once as the loop device, once as the btrfs page cache).
sudo install -m 755 /dev/stdin "${HELPER}" <<EOF
#!/usr/bin/env bash
set -euo pipefail

# Generated by mise run bootstrap:cargo-target-fs. Manages the loopback btrfs
# filesystem backing ${MOUNTPOINT}.

IMAGE="${IMAGE}"
MOUNTPOINT="${MOUNTPOINT}"
OWNER="${USER}"

find_loop() {
    losetup --noheadings --output NAME --associated "\${IMAGE}" | head -n1
}

case "\${1:-}" in
mount)
    if mountpoint -q "\${MOUNTPOINT}"; then
        exit 0
    fi
    mkdir -p "\${MOUNTPOINT}"

    loop="\$(find_loop)"
    if [[ -z "\${loop}" ]]; then
        # direct-io avoids caching image bytes twice (loop device + btrfs).
        loop="\$(losetup --find --show --direct-io=on "\${IMAGE}")"
    fi

    # compress-force because btrfs's per-file compressibility heuristic bails on
    # some artifacts that zstd compresses fine anyway; discard=async so btrfs
    # deletions punch holes back into the sparse image, keeping it small.
    mount -o noatime,compress-force=zstd:3,discard=async "\${loop}" "\${MOUNTPOINT}"
    chown "\${OWNER}" "\${MOUNTPOINT}"
    ;;
umount)
    if mountpoint -q "\${MOUNTPOINT}"; then
        umount "\${MOUNTPOINT}"
    fi
    loop="\$(find_loop)"
    if [[ -n "\${loop}" ]]; then
        losetup --detach "\${loop}"
    fi
    ;;
*)
    echo "usage: cargo-target-fs {mount|umount}" >&2
    exit 2
    ;;
esac
EOF

# System-level units (mirrors the idle-shutdown pattern in vm:create-post).
sudo install -m 644 /dev/stdin /etc/systemd/system/cargo-target-fs.service <<EOF
[Unit]
Description=Mount compressed btrfs filesystem at ${MOUNTPOINT}
RequiresMountsFor=${IMAGE}

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=${HELPER} mount
ExecStop=${HELPER} umount

[Install]
WantedBy=multi-user.target
EOF

# duperemove scans the tree and merges identical extents; fstrim then releases
# the freed extents back into the sparse image. Runs unprivileged as the owning
# user (its files), except fstrim which needs root (the `+` prefix). The
# hashfile lives OUTSIDE the scanned tree so it is not itself deduped/rewritten
# mid-scan.
sudo install -m 644 /dev/stdin /etc/systemd/system/cargo-target-dedupe.service <<EOF
[Unit]
Description=Dedupe and trim the compressed btrfs filesystem at ${MOUNTPOINT}
After=cargo-target-fs.service
ConditionPathIsMountPoint=${MOUNTPOINT}

[Service]
Type=oneshot
User=${USER}
Nice=19
IOSchedulingClass=idle
CPUSchedulingPolicy=batch
# duperemove logs one line per deduped extent — drop stdout, keep errors.
StandardOutput=null
StandardError=journal
ExecStart=/usr/bin/duperemove -dr --hashfile=${HASHFILE} ${MOUNTPOINT}
ExecStartPost=+/usr/sbin/fstrim ${MOUNTPOINT}
EOF

# OnUnitInactiveSec fires 10min after each completion (not each start), so a
# long first scan can never overlap its next run.
sudo install -m 644 /dev/stdin /etc/systemd/system/cargo-target-dedupe.timer <<EOF
[Unit]
Description=Periodic dedupe + trim of ${MOUNTPOINT}

[Timer]
OnBootSec=10min
OnUnitInactiveSec=10min
RandomizedDelaySec=1min
Unit=cargo-target-dedupe.service

[Install]
WantedBy=timers.target
EOF

# duperemove creates the hashfile but not its parent directory.
mkdir -p "$(dirname "${HASHFILE}")"

sudo systemctl daemon-reload
sudo systemctl enable --now cargo-target-fs.service
sudo systemctl enable --now cargo-target-dedupe.timer

if ! mountpoint -q "${MOUNTPOINT}"; then
    echo "cargo-target-fs: FAILED to mount ${MOUNTPOINT}." >&2
    sudo systemctl status cargo-target-fs.service --no-pager -l >&2 || true
    exit 1
fi

echo "cargo-target-fs: mounted ${MOUNTPOINT}"
echo "  image:   ${IMAGE} ($(du -h --apparent-size "${IMAGE}" | cut -f1) virtual)"
echo "  options: noatime,compress-force=zstd:3,discard=async (loop DIO)"
echo "  dedupe:  cargo-target-dedupe.timer (every 10min after completion)"
