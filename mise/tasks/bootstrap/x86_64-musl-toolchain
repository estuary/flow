#!/usr/bin/env bash
set -euo pipefail

#MISE description="Install x86_64-linux-musl cross-compilation toolchain (aarch64 hosts only)"
#MISE depends=["bootstrap:apt-packages-ci-extra"]
#MISE sources=["."]

# Only run on aarch64 hosts
ARCH=$(uname -m)
if [ "$ARCH" != "aarch64" ]; then
    echo "Skipping: This toolchain is only needed on aarch64 hosts"
    exit 0
fi

echo "Setting up x86_64-linux-musl cross-compilation toolchain..."

# Version should match what's in Ubuntu repos
MUSL_VERSION="1.2.4-2"

# Set up directories
MUSL_ROOT="${HOME}/x86_64-musl-${MUSL_VERSION}"
BIN_DIR="${HOME}/.local/bin"

mkdir -p "${MUSL_ROOT}"
mkdir -p "${BIN_DIR}"

# Download amd64 musl packages if not already done
CACHE_DIR="/tmp/musl-x86_64-packages"
mkdir -p "${CACHE_DIR}"

BASE_URL="http://archive.ubuntu.com/ubuntu/pool/universe/m/musl"

for pkg in musl musl-dev musl-tools; do
    DEB_FILE="${CACHE_DIR}/${pkg}_${MUSL_VERSION}_amd64.deb"
    if [ ! -f "${DEB_FILE}" ]; then
        echo "Downloading ${pkg}..."
        wget -q -O "${DEB_FILE}" "${BASE_URL}/${pkg}_${MUSL_VERSION}_amd64.deb"
    else
        echo "✓ ${pkg} package already cached"
    fi
done

# Extract packages to musl root
echo "Extracting musl packages to ${MUSL_ROOT}..."
for deb in "${CACHE_DIR}"/*.deb; do
    dpkg-deb -x "$deb" "${MUSL_ROOT}/"
done

# Move extracted files from usr/ to root of MUSL_ROOT
if [ -d "${MUSL_ROOT}/usr" ]; then
    rsync -a "${MUSL_ROOT}/usr/" "${MUSL_ROOT}/"
    rm -rf "${MUSL_ROOT}/usr"
fi

# Create updated musl-gcc.specs with absolute paths
cat > "${MUSL_ROOT}/lib/x86_64-linux-musl/musl-gcc.specs" <<EOF
%rename cpp_options old_cpp_options

*cpp_options:
-nostdinc -isystem ${MUSL_ROOT}/include/x86_64-linux-musl -isystem include%s %(old_cpp_options)

*cc1:
%(cc1_cpu) -nostdinc -isystem ${MUSL_ROOT}/include/x86_64-linux-musl -isystem include%s

*link_libgcc:
-L${MUSL_ROOT}/lib/x86_64-linux-musl -L .%s

*libgcc:
libgcc.a%s %:if-exists(libgcc_eh.a%s)

*startfile:
%{shared:;static-pie:${MUSL_ROOT}/lib/x86_64-linux-musl/rcrt1.o; :${MUSL_ROOT}/lib/x86_64-linux-musl/Scrt1.o} ${MUSL_ROOT}/lib/x86_64-linux-musl/crti.o crtbeginS.o%s

*endfile:
crtendS.o%s ${MUSL_ROOT}/lib/x86_64-linux-musl/crtn.o

*link:
-dynamic-linker /lib/ld-musl-x86_64.so.1 -nostdlib %{shared:-shared} %{static:-static} %{static-pie:-static -pie --no-dynamic-linker} %{rdynamic:-export-dynamic}

*esp_link:


*esp_options:


*esp_cpp_options:


EOF

# Create wrapper scripts in MUSL_ROOT/bin
mkdir -p "${MUSL_ROOT}/bin"

cat > "${MUSL_ROOT}/bin/x86_64-linux-musl-gcc" <<EOF
#!/bin/sh
# x86_64-linux-musl-gcc wrapper for cross-compilation on aarch64
# This script invokes the x86-64 cross-compiler with musl libc
MUSL_ROOT="${MUSL_ROOT}"
exec x86_64-linux-gnu-gcc "\$@" -specs "\${MUSL_ROOT}/lib/x86_64-linux-musl/musl-gcc.specs"
EOF

chmod +x "${MUSL_ROOT}/bin/x86_64-linux-musl-gcc"

# Create ar wrapper (needed for static libraries)
cat > "${MUSL_ROOT}/bin/x86_64-linux-musl-ar" <<'EOF'
#!/bin/sh
# x86_64-linux-musl-ar wrapper
exec x86_64-linux-gnu-ar "$@"
EOF

chmod +x "${MUSL_ROOT}/bin/x86_64-linux-musl-ar"

# Create symlinks in ~/.local/bin
ln -sf "${MUSL_ROOT}/bin/x86_64-linux-musl-gcc" "${BIN_DIR}/x86_64-linux-musl-gcc"
ln -sf "${MUSL_ROOT}/bin/x86_64-linux-musl-ar" "${BIN_DIR}/x86_64-linux-musl-ar"

# Verify installation
echo ""
echo "✓ x86_64-linux-musl toolchain installed successfully!"
echo ""
echo "Installed to:"
echo "  Toolchain:    ${MUSL_ROOT}"
echo "  Wrappers:     ${MUSL_ROOT}/bin/x86_64-linux-musl-{gcc,ar}"
echo "  Symlinks:     ${BIN_DIR}/x86_64-linux-musl-{gcc,ar}"
echo ""
echo "Testing toolchain..."

# Test that the wrapper works
if "${BIN_DIR}/x86_64-linux-musl-gcc" --version > /dev/null 2>&1; then
    echo "✓ Toolchain test passed"
else
    echo "✗ Toolchain test failed"
    exit 1
fi

echo ""
echo "Make sure ${BIN_DIR} is in your PATH"
