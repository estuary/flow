#!/usr/bin/env bash
set -euo pipefail

#MISE hide=true

mise run bootstrap:apt-packages-ci-base
mise install
mise run bootstrap:vscode-settings

# Install cockpit for web-based system management.
sudo DEBIAN_FRONTEND=noninteractive apt-get install -y cockpit
# Set a user password for cockpit login (user: current user).
echo "${USER}:admin" | sudo chpasswd

# Configure rootful (system) podman instead of rootless.
# This better mirrors production environments where containers run as root.

# Create a `podman` group with access to the podman socket.
sudo groupadd podman 2> /dev/null || true
sudo mkdir -p /run/podman
sudo chgrp podman /run/podman
sudo chmod g+rx   /run/podman

# Configure podman socket to be accessible by the podman group.
# Security note: This gives users in the podman group effective root access,
# equivalent to Docker's security model where docker group members have root.
# This is acceptable in isolated dev VMs where users already have sudo access.
sudo mkdir -p /etc/systemd/system/podman.socket.d
sudo tee /etc/systemd/system/podman.socket.d/override.conf > /dev/null << 'EOF'
[Socket]
SocketMode=0660
SocketGroup=podman
EOF

# Configure podman to allow non-root users in the podman group to use rootful podman.
sudo mkdir -p /etc/containers/containers.conf.d
sudo tee /etc/containers/containers.conf.d/rootful.conf > /dev/null << 'EOF'
[engine]
# Allow users in the podman group to use the system podman socket
cgroup_manager = "systemd"
events_logger = "journald"
EOF

# Silence warning from `podman-docker` when using the `docker` compatibility shim.
sudo touch /etc/containers/nodocker

# Restart system-wide podman socket to apply configuration.
sudo systemctl daemon-reload
sudo systemctl restart podman.socket

# Grant the user access to the podman group and systemd journals.
sudo usermod -aG podman ${USER}
sudo usermod -aG systemd-journal ${USER}

# Add additional .bashrc configuration if not already present.
if ! grep -q "CONTAINER_HOST.*podman.sock" "${HOME}/.bashrc"; then
cat >> "${HOME}/.bashrc" << 'EOF'
# Podman socket path (rootful/system socket)
# CONTAINER_HOST: Used by native podman / podman-docker CLI
# DOCKER_HOST: Used by native Docker API clients (e.x. supabase)
export CONTAINER_HOST="unix:///run/podman/podman.sock"
export    DOCKER_HOST="unix:///run/podman/podman.sock"

# Source mise hooks for directory activation and CLI completion.
source <(${HOME}/.local/bin/mise activate bash)
source <(${HOME}/.local/bin/mise completion bash --include-bash-completion-lib)

EOF
fi
