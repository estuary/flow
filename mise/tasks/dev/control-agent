#!/usr/bin/env bash
set -euo pipefail

#MISE description="Start control plane agent via systemd"
#MISE depends=["dev:common", "dev:tls-cert", "dev:supabase"]

FLOW_LOCAL="${HOME}/flow-local"
mkdir -p "${FLOW_LOCAL}/env"

cat > "${FLOW_LOCAL}/env/agent.env" <<EOF
# Agent environment
# Generated by mise ($(date))

# SSL_CERT_FILE is required for calls made to brokers and reactors.

ALLOW_ORIGIN=http://localhost:3000
API_PORT=8675
BUILDS_ROOT=file://${FLOW_LOCAL}/builds/
CONNECTOR_NETWORK=supabase_network_flow
CONTROL_PLANE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
DATABASE_URL=postgresql://postgres:postgres@db.flow.localhost:5432/postgres
LOG_FORMAT=text
MAX_AUTOMATIONS=10
NO_COLOR=1
RUST_LOG=info
SERVE_HANDLERS=true
SKIP_CONNECTOR_TABLE_CHECK=true
SSL_CERT_FILE=${FLOW_LOCAL}/ca.crt

EOF

# Link systemd unit if not already linked
UNIT_FILE="${HOME}/.config/systemd/user/flow-control-agent.service"
if [ ! -f "$UNIT_FILE" ]; then
    mkdir -p "${HOME}/.config/systemd/user"
    ln -sf "$(pwd)/systemd/flow-control-agent.service" "$UNIT_FILE"
    systemctl --user daemon-reload
    echo "Linked flow-control-agent.service"
fi

# Start the service
echo "Starting flow-control-agent..."
systemctl --user start flow-control-agent

echo "Control-plane agent started. Check status with: systemctl --user status flow-control-agent"
echo "View logs with: journalctl --user -u flow-control-agent -f"
