#!/usr/bin/env bash
set -euo pipefail

#MISE description="Start gazette broker via systemd"
#MISE depends=["dev:etcd", "dev:tls-cert"]
#USAGE arg "<broker_cluster>" help="Name of the broker cluster"
#USAGE arg "<broker_port>" help="Broker port to listen on"

BROKER_CLUSTER="${usage_broker_cluster}"
BROKER_PORT="${usage_broker_port}"
INSTANCE="${BROKER_CLUSTER}-${BROKER_PORT}"

FLOW_LOCAL="${HOME}/flow-local"
mkdir -p "${FLOW_LOCAL}/env"

# Generate gazette instance-specific environment file
cat > "${FLOW_LOCAL}/env/gazette-${INSTANCE}.env" <<EOF
# Gazette broker environment for ${INSTANCE}
# Generated by mise ($(date))

# Authorization keys are the base64-encoding of "broker-${BROKER_CLUSTER}".

BROKER_ALLOW_ORIGIN=http://localhost:3000
BROKER_AUTH_KEYS=$(echo -n "broker-${BROKER_CLUSTER}" | base64 | tr -d '\n')
BROKER_AUTO_SUSPEND=true
BROKER_FILE_ONLY=true
BROKER_FILE_ROOT=${FLOW_LOCAL}
BROKER_HOST=broker-${BROKER_CLUSTER}.flow.localhost
BROKER_PEER_CA_FILE=${FLOW_LOCAL}/ca.crt
BROKER_PORT=${BROKER_PORT}
BROKER_SERVER_CERT_FILE=${FLOW_LOCAL}/server.crt
BROKER_SERVER_CERT_KEY_FILE=${FLOW_LOCAL}/server.key
ETCD_ADDRESS=http://etcd.flow.localhost:2379
ETCD_PREFIX=/gazette/${BROKER_CLUSTER}
LOG_LEVEL=info
EOF

echo "Generated ${HOME}/flow-local/env/gazette-${INSTANCE}.env"

# Link systemd template unit if not already linked
TEMPLATE_UNIT="${HOME}/.config/systemd/user/flow-gazette@.service"
if [ ! -f "$TEMPLATE_UNIT" ]; then
    mkdir -p "${HOME}/.config/systemd/user"
    ln -sf "$(pwd)/systemd/flow-gazette@.service" "$TEMPLATE_UNIT"
    systemctl --user daemon-reload
    echo "Linked flow-gazette@.service template"
fi

# Start the service instance
echo "Starting flow-gazette@${INSTANCE}..."
systemctl --user start "flow-gazette@${INSTANCE}"

echo "Gazette broker ${INSTANCE} started."
echo "Check status with: systemctl --user status flow-gazette@${INSTANCE}"
echo "View logs with: journalctl --user -u flow-gazette@${INSTANCE} -f"
echo "Access at: https://broker-${BROKER_CLUSTER}.flow.localhost:${BROKER_PORT}/debug/pprof"
