#!/usr/bin/env bash
set -euo pipefail

#MISE description="Start flow reactor via systemd"
#MISE depends=["dev:etcd", "dev:tls-cert"]
#USAGE arg "<reactor_cluster>" help="Name of the reactor cluster"
#USAGE arg "<reactor_port>" help="Reactor port to listen on"
#USAGE arg "<broker_cluster>" help="Name of the broker cluster"
#USAGE arg "<broker_port>" help="Seed port to discover broker cluster"

REACTOR_CLUSTER="${usage_reactor_cluster}"
REACTOR_PORT="${usage_reactor_port}"
BROKER_CLUSTER="${usage_broker_cluster}"
BROKER_PORT="${usage_broker_port}"
INSTANCE="${REACTOR_CLUSTER}-${REACTOR_PORT}"

FLOW_LOCAL="${HOME}/flow-local"
mkdir -p "${FLOW_LOCAL}/env"

# Generate reactor instance-specific environment file
cat > "${FLOW_LOCAL}/env/reactor-${INSTANCE}.env" <<EOF
# Reactor environment for ${INSTANCE}
# Generated by mise ($(date))

# Authorization keys are the base64-encodings of "broker-${BROKER_CLUSTER}"
# and "reactor-${REACTOR_CLUSTER}".

# Note the local cert is signed with a wildcard of *.flow.localhost.
# CONSUMER_HOST must match for the connector networking feature to function.

BROKER_ADDRESS=https://broker-${BROKER_CLUSTER}.flow.localhost:${BROKER_PORT}
BROKER_AUTH_KEYS=$(echo -n "broker-${BROKER_CLUSTER}" | base64 | tr -d '\n')
BROKER_CACHE_SIZE=128
BROKER_FILE_ROOT=${FLOW_LOCAL}
BROKER_TRUSTED_CA_FILE=${FLOW_LOCAL}/ca.crt
CONSUMER_ALLOW_ORIGIN=http://localhost:3000
CONSUMER_AUTH_KEYS=$(echo -n "reactor-${REACTOR_CLUSTER}" | base64 | tr -d '\n')
CONSUMER_HOST=flow.localhost
CONSUMER_LIMIT=1024
CONSUMER_PEER_CA_FILE=${FLOW_LOCAL}/ca.crt
CONSUMER_PORT=${REACTOR_PORT}
CONSUMER_SERVER_CERT_FILE=${FLOW_LOCAL}/server.crt
CONSUMER_SERVER_CERT_KEY_FILE=${FLOW_LOCAL}/server.key
DOCKER_DEFAULT_PLATFORM=linux/amd64
ETCD_ADDRESS=http://etcd.flow.localhost:2379
ETCD_PREFIX=/flow/${REACTOR_CLUSTER}
FLOW_ALLOW_LOCAL=true
FLOW_BUILDS_ROOT=file://${FLOW_LOCAL}/builds/
FLOW_CONTROL_API=http://agent.flow.localhost:8675
FLOW_DASHBOARD=http://localhost:3000
FLOW_DATA_PLANE_FQDN=reactor-${REACTOR_CLUSTER}.dp.estuary-data.com
FLOW_NETWORK=supabase_network_flow
LOG_LEVEL=info
SSL_CERT_FILE=${FLOW_LOCAL}/ca.crt # Required for agent API calls.
EOF

echo "Generated ${HOME}/flow-local/env/reactor-${INSTANCE}.env"

# Link systemd template unit if not already linked
TEMPLATE_UNIT="${HOME}/.config/systemd/user/flow-reactor@.service"
if [ ! -f "$TEMPLATE_UNIT" ]; then
    mkdir -p "${HOME}/.config/systemd/user"
    ln -sf "$(pwd)/systemd/flow-reactor@.service" "$TEMPLATE_UNIT"
    systemctl --user daemon-reload
    echo "Linked flow-reactor@.service template"
fi

# Start the service instance
echo "Starting flow-reactor@${INSTANCE}..."
systemctl --user start "flow-reactor@${INSTANCE}"

echo "Reactor ${INSTANCE} started."
echo "Check status with: systemctl --user status flow-reactor@${INSTANCE}"
echo "View logs with: journalctl --user -u flow-reactor@${INSTANCE} -f"
echo "Access at: https://reactor-${REACTOR_CLUSTER}.flow.localhost:${REACTOR_PORT}/debug/pprof"
