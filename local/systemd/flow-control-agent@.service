[Unit]
Description=Flow Control Plane Agent (%i)
Documentation=https://github.com/estuary/flow
After=flow-supabase@%i.service
Requires=flow-supabase@%i.service
After=flow-bigtable@%i.service
Requires=flow-bigtable@%i.service
PartOf=flow-control-plane@%i.target

[Service]
Type=simple
TimeoutStartSec=600

EnvironmentFile=%h/flow-local/env/agent-%i.env

ExecStartPre=sh -c 'cd ${FLOW_ROOT} && cargo build -p agent'
# Two CORS allow-origins: the global external UI (FLOW_DASHBOARD_ORIGIN,
# http://localhost:3000), plus the optional per-stack UI at base+5. Both vars
# come from the EnvironmentFile above.
ExecStart=sh -c 'exec ${CARGO_TARGET_DIR}/debug/agent --allow-origin ${FLOW_DASHBOARD_ORIGIN} --allow-origin http://localhost:${FLOW_PORT_DASHBOARD}'

Restart=on-failure
RestartSec=5s
